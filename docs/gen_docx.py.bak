"""生成万泰技术文档 docx —— 内容与 .tex 版本一致,带样式(标题/表格/代码/配色)"""
from docx import Document
from docx.shared import Pt, RGBColor, Cm, Inches
from docx.enum.text import WD_ALIGN_PARAGRAPH
from docx.enum.table import WD_TABLE_ALIGNMENT
from docx.oxml.ns import qn
from docx.oxml import OxmlElement

# ===== 配色 =====
GOLD = RGBColor(0xC9, 0x85, 0x00)
BLUE = RGBColor(0x39, 0x87, 0xE5)
DARK = RGBColor(0x1A, 0x1A, 0x19)
GRAY = RGBColor(0x80, 0x80, 0x80)
WHITE = RGBColor(0xFF, 0xFF, 0xFF)
CODE_BG = "F5F5F3"

doc = Document()

# ===== 全局字体(中文宋体/黑体,正文等线) =====
style = doc.styles['Normal']
style.font.name = '等线'
style.font.size = Pt(10.5)
style.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')

# 页边距
for section in doc.sections:
    section.top_margin = Cm(2.5)
    section.bottom_margin = Cm(2.5)
    section.left_margin = Cm(2.5)
    section.right_margin = Cm(2.5)


def set_cell_bg(cell, color_hex):
    """单元格背景色"""
    tc_pr = cell._tc.get_or_add_tcPr()
    shd = OxmlElement('w:shd')
    shd.set(qn('w:val'), 'clear')
    shd.set(qn('w:fill'), color_hex)
    tc_pr.append(shd)


def add_heading(text, level=1, color=GOLD):
    """带颜色的标题"""
    h = doc.add_heading('', level=level)
    run = h.add_run(text)
    run.font.color.rgb = color
    run.font.name = '黑体'
    run.element.rPr.rFonts.set(qn('w:eastAsia'), '黑体')
    return h


def add_para(text, bold=False, color=None, size=10.5, align=None):
    p = doc.add_paragraph()
    run = p.add_run(text)
    run.bold = bold
    run.font.size = Pt(size)
    run.font.name = '等线'
    run.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    if color:
        run.font.color.rgb = color
    if align:
        p.alignment = align
    return p


def add_bullet(text, bold_prefix=None):
    p = doc.add_paragraph(style='List Bullet')
    if bold_prefix:
        r1 = p.add_run(bold_prefix)
        r1.bold = True
        r1.font.name = '等线'
        r1.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    r = p.add_run(text)
    r.font.name = '等线'
    r.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    return p


def add_number(text):
    p = doc.add_paragraph(style='List Number')
    r = p.add_run(text)
    r.font.name = '等线'
    r.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    return p


def add_code(text):
    """代码块:灰底等宽"""
    p = doc.add_paragraph()
    p.paragraph_format.left_indent = Cm(0.5)
    p.paragraph_format.space_before = Pt(4)
    p.paragraph_format.space_after = Pt(4)
    # 段落背景
    p_pr = p._p.get_or_add_pPr()
    shd = OxmlElement('w:shd')
    shd.set(qn('w:val'), 'clear')
    shd.set(qn('w:fill'), CODE_BG)
    p_pr.append(shd)
    for line in text.split('\n'):
        run = p.add_run(line + '\n')
        run.font.name = 'Consolas'
        run.font.size = Pt(9)
        run.font.color.rgb = DARK


def add_table(headers, rows, col_widths=None):
    """带表头的表格"""
    t = doc.add_table(rows=1 + len(rows), cols=len(headers))
    t.style = 'Light Grid Accent 1'
    t.alignment = WD_TABLE_ALIGNMENT.CENTER
    # 表头
    for i, h in enumerate(headers):
        cell = t.rows[0].cells[i]
        cell.text = ''
        p = cell.paragraphs[0]
        run = p.add_run(h)
        run.bold = True
        run.font.color.rgb = WHITE
        run.font.size = Pt(10)
        run.font.name = '黑体'
        run.element.rPr.rFonts.set(qn('w:eastAsia'), '黑体')
        set_cell_bg(cell, 'C98500')
    # 数据行
    for r_idx, row in enumerate(rows):
        for c_idx, val in enumerate(row):
            cell = t.rows[r_idx + 1].cells[c_idx]
            cell.text = ''
            p = cell.paragraphs[0]
            run = p.add_run(str(val))
            run.font.size = Pt(9.5)
            run.font.name = '等线'
            run.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    return t


def add_highlight_box(title, lines):
    """高亮盒子(用单行表格模拟)"""
    t = doc.add_table(rows=1, cols=1)
    t.alignment = WD_TABLE_ALIGNMENT.CENTER
    cell = t.rows[0].cells[0]
    set_cell_bg(cell, 'FFF4E0')  # 浅金
    cell.text = ''
    p = cell.paragraphs[0]
    run = p.add_run(title)
    run.bold = True
    run.font.color.rgb = GOLD
    run.font.size = Pt(11)
    run.font.name = '黑体'
    run.element.rPr.rFonts.set(qn('w:eastAsia'), '黑体')
    for line in lines:
        bp = cell.add_paragraph()
        r = bp.add_run(line)
        r.font.size = Pt(10)
        r.font.name = '等线'
        r.element.rPr.rFonts.set(qn('w:eastAsia'), '等线')
    doc.add_paragraph()  # 间距


