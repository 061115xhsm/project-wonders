# ============ 9. 部署 ============
add_heading('9. 部署方案', 1)
add_heading('9.1 本地运行', 2)
add_code('''# 1. 安装依赖
pip install -r requirements.txt

# 2. 配置大模型密钥(项目根 .env)
LLM_PRIMARY_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
LLM_PRIMARY_API_KEY=your_key
LLM_PRIMARY_MODEL=auto

# 3. 生成数据(首次)
python3 -m app.data_generator

# 4. 启动
streamlit run app/main.py --server.port 8501''')
add_heading('9.2 公网部署', 2)
add_para('采用 cloudflared 内网穿透（无需公网 IP / 备案）：')
add_code('''# 临时隧道(随机域名)
~/.local/bin/cloudflared tunnel --url http://localhost:8501

# 命名隧道(固定域名,需 Cloudflare 账号 + 域名)
~/.local/bin/cloudflared tunnel create wantai
~/.local/bin/cloudflared tunnel route dns wantai fodeshou.vvvv.ee
~/.local/bin/cloudflared tunnel run wantai''')
add_heading('9.3 配置优化', 2)
add_bullet('字体改系统字体栈（不联网加载 Google Fonts）')
add_bullet('fileWatcherType=none + runOnSave=false（减少后台开销）')
add_bullet('公网首屏延迟 0.7~1.1 秒')

