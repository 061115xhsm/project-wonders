             ('AI 运营日报', '首页基于全局统计生成 3 条可行动洞察')]:
    add_bullet(d, t + '：')
add_heading('4.6 AI 实干度保障', 2)
add_highlight_box('防"假AI"机制', [
    'json_mode：要求 JSON 的函数启用 response_format=json_object，减少 fallback',
    'source 标记：UI 用 _source 字段判断来源（含 "llm" 才标"AI生成"），不误标',
    'ROI 防造假：system prompt 约束 1-6x，AI 返回越界则用 fallback ROI 替换',
    '宽松验收：只要含关键结构字段即接受，不因字段不全降级',
])

# ============ 5. 算法层 ============
add_heading('5. 算法层', 1)
add_heading('5.1 RFM 会员分层', 2)
add_para('RFM 模型：R=最近到店天数（越小越好），F=到店次数（越大越好），M=累计消费（越大越好）。')
add_number('对 R/F/M 三维特征做 K-Means 聚类（K=4）')
add_number('按聚类中心综合评分 (-R + F + M) 降序')
add_number('动态映射标签（不硬编码簇编号）：评分最高→高价值，依次→潜力/新客/沉睡')
add_para('输出四类群体：高价值（核心利润）/ 潜力（升级空间）/ 新客（需培养）/ 沉睡（需召回）。')
add_heading('5.2 商铺综合评分', 2)
add_para('Score = 0.4×销售 + 0.3×客流 + 0.2×租售比 + 0.1×转化率', bold=True)
add_para('各指标 Min-Max 归一化后加权求和，分数 0-100。租售比 = 月租 / 中位数月租（相对租金贡献）。')
add_heading('5.3 客流时空模型', 2)
add_para('build_traffic_function 构建 7（星期）× 24（时段）客流矩阵，用于热力图可视化与峰值识别。')
add_heading('5.4 天气/节假日效应', 2)
add_bullet('晴/阴/雨天平均客流对比', 'analyze_weather_impact：')
add_bullet('工作日/周末/节假日客流倍数', 'analyze_holiday_effect：')

# ============ 6. 痛点解决方案 ============
add_heading('6. 5 大痛点解决方案', 1)
pains = [
    ('6.1 痛点①：客流画像缺失', '客流分析 + 数据采集', [
        '7×24 时空热力图（红蓝全色谱渐变，3000 断点）定位高峰',
        '天气/节假日 × 楼层分组对比',
        'AI 客流人群画像：Agent 基于时空规律生成"识人"总结',
        '采集覆盖率看板 + 缺失预警 + AI 采集建议']),
    ('6.2 痛点②：营销割裂', '全渠道营销', [
        '统一会员 ID 体系（设计中）：贯通小程序/门店 POS/支付/营销',
        '线上线下触点矩阵 + 桑基流向图',
        '跨触点会员旅程（线上领券→门店核销→积分回传→RFM更新→精准复购）',
        '系统对接方案（万泰 SaaS/OA/POS/IoT 接口预留）']),
    ('6.3 痛点③：数字化获客困难', '数字化获客', [
        '获客渠道分布 + 渠道质量对比',
        '数字化获客漏斗（触达→注册→首单→复购）',
        '渠道 ROI 对比（按行业基准，需 AB 测试校准）',
        'AI 拉新方案：选渠道→Agent 生成裂变/券码/地推方案 + 执行出口']),
    ('6.4 痛点④：数据采集缺失', '数据采集', [
        '采集覆盖率（整体/楼层/业态/主力店）',
        '缺失预警表（采集率 < 70% 商铺 + 缺失字段）',
        '数据资产盘点（客流/销售/会员/合同/转化 各类采集状态）',
        'AI 采集建议：低覆盖商铺→Agent 生成可执行采集方案']),
    ('6.5 痛点⑤：租户管理繁琐', '租户管理', [
        '合同到期看板（60 天内到期 + 已逾期）',
        '收租进度（已收/待收/逾期 + 各楼层收租率）',
        '租售比预警（>30% 经营压力大，红色预警）',
        'AI 催租话术：选逾期商户→Agent 生成合规话术 + 执行出口']),
]
for title, page, items in pains:
    add_heading(title, 2)
    add_para('对应页面：' + page, bold=True)
    add_para('解决方式：', bold=True)
    for it in items:
        add_bullet(it)
add_heading('6.6 痛点闭环', 2)
add_para('每个痛点都形成"展示→洞察→决策→执行→回算"闭环，而非止于展示：')
add_code('数据展示 → AI 洞察 → 结构化方案 → 执行出口(复制/导出/标记已执行) → 录入实际效果 → 回算真实ROI')

