])
add_para('检索流程：')
add_number('build_index()：语料向量化（384 维 MiniLM）→ L2 归一化 → pickle 缓存到 data/rag_index/')
add_number('retrieve(query, k=4)：查询向量化 → 余弦相似度（点积）→ top-k')
add_number('retrieve_text()：拼接成文本注入大模型 context')
add_code('''# 离线部署:模型已缓存本地,不联网检查更新
os.environ["HF_HUB_OFFLINE"] = "1"
os.environ["TRANSFORMERS_OFFLINE"] = "1"
model = SentenceTransformer("paraphrase-multilingual-MiniLM-L12-v2")''')
add_heading('4.4 ReAct 营销 Agent（核心创新）', 2)
add_para('设计动机：', bold=True)
add_para('传统方案是"硬编码先检索再生成"的单次 LLM 调用，不是真 Agent。本项目将营销 Agent 升级为 ReAct（Reasoning + Acting）多步工具调用——大模型自主决定调哪些工具、调几次，这才是名副其实的 Agent。')
add_para('工具注册表（Agent 可自主调用 4 个工具）：', bold=True)
add_table(['工具', '功能', '返回'], [
    ['query_member_segment', '查 RFM 群体真实统计', '人数/均消费/均到店/等级分布'],
    ['query_shop_ranking', '查商铺综合评分排行', 'top 商铺（可按业态/楼层筛选）'],
    ['retrieve_knowledge', 'RAG 检索商场知识库', '相关语料文本'],
    ['estimate_roi', '估算营销 ROI', '转化率/增收/成本/ROI'],
])
add_para('ReAct 循环：', bold=True)
add_code('''for step in range(6):  # 最多6轮工具调用
    r = chat(messages, temperature=0.4, json_mode=False)
    decision = parse_json_response(r["content"])

    if decision["action"] == "tool":
        result = _call_tool(decision["tool"], decision["args"])
        messages.append({"role":"user", "content": f"工具结果: {result}"})
    elif decision["action"] == "final":
        plan = decision["plan"]  # 最终结构化方案
        return plan''')
add_para('实测轨迹（沉睡群体，Agent 自主执行 3 步工具调用）：', bold=True)
add_number('调 retrieve_knowledge("沉睡会员唤醒营销方法论") → 检索到沉睡策略')
add_number('调 query_shop_ranking(category="餐饮") → 拿到喜茶/霸王茶姬真实排行')
add_number('调 estimate_roi(segment="沉睡", count=1250, avg_spent=3200) → ROI=4.0x')
add_number('基于工具结果生成方案：选品用真实商户，话术含"满300立减60+赠喜茶"，ROI 4.0x')
add_heading('4.5 其他 AI 能力', 2)
for t, d in [('多轮运营对话', '注入真实数据 facts + RAG + 对话历史，支持追问上下文'),
