add_heading('3.4 数据脱敏', 2)
add_para('processor.py 的 mask_sensitive_data 函数对敏感字段脱敏：')
add_code('''# 手机号脱敏: 13812345678 -> 138****5678
# 姓名脱敏:   王小明 -> 王**
# 身份证号:   不存储
def mask_sensitive_data(df):
    if 'phone' in df.columns:
        df['phone'] = df['phone'].str[:3] + '****' + df['phone'].str[-4:]
    if 'name' in df.columns:
        df['name'] = df['name'].str[0] + '*' * (df['name'].str.len() - 1)
    return df''')

