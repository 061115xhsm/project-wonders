add_para('Project WONDERS', color=GRAY, size=14, align=WD_ALIGN_PARAGRAPH.CENTER)
doc.add_paragraph()
add_para('让商场从"凭经验"转向"看数据做决策"', bold=True, size=14, align=WD_ALIGN_PARAGRAPH.CENTER)
add_para('AI 驱动的商场运营决策系统 · RAG 知识库 + Agent + 大模型', color=GRAY, size=12, align=WD_ALIGN_PARAGRAPH.CENTER)
for _ in range(6):
    doc.add_paragraph()
# 封面信息表
info = [['赛道', 'AI + 软件 · 地产商贸'], ['企业', '广东万泰集团'], ['团队', '佛得首队'],
        ['成员', '巫焕奇  刘哲润'], ['版本', 'V2.0'], ['日期', '2026 年 7 月']]
t = doc.add_table(rows=len(info), cols=2)
t.alignment = WD_TABLE_ALIGNMENT.CENTER
for i, (k, v) in enumerate(info):
    c1, c2 = t.rows[i].cells
    c1.text = ''; r = c1.paragraphs[0].add_run(k); r.bold = True; r.font.size = Pt(11); r.font.color.rgb = GOLD
    c2.text = ''; r = c2.paragraphs[0].add_run(v); r.font.size = Pt(11)
doc.add_page_break()

# ============ 目录(Word打开后可更新) ============
add_heading('目录', level=1)
add_para('（在 Word 中按 Ctrl+A 全选 → F9 可更新目录字段）', color=GRAY, size=9)
# 插入TOC字段
p = doc.add_paragraph()
run = p.add_run()
fld = OxmlElement('w:fldChar'); fld.set(qn('w:fldCharType'), 'begin'); run._r.append(fld)
instr = OxmlElement('w:instrText'); instr.set(qn('xml:space'), 'preserve'); instr.text = 'TOC \\o "1-3" \\h \\z \\u'; run._r.append(instr)
fld2 = OxmlElement('w:fldChar'); fld2.set(qn('w:fldCharType'), 'separate'); run._r.append(fld2)
fld3 = OxmlElement('w:fldChar'); fld3.set(qn('w:fldCharType'), 'end'); run._r.append(fld3)
